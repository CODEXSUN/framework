{
  "name": "@codexsun/framework",
  "version": "1.0.44",
  "private": false,
  "description": "CODEXSUN framework runtime and stable application contracts",
  "type": "module",
  "files": [
    "dist",
    "src",
    "api.js",
    "config.js",
    "db.js",
    "env.js",
    "errors.js",
    "events.js",
    "health.js",
    "http.js",
    "index.js",
    "logger.js",
    "modules.js",
    "queue.js",
    "storage.js",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./index.js"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "default": "./api.js"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "default": "./config.js"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "default": "./db.js"
    },
    "./env": {
      "types": "./src/env/index.ts",
      "default": "./env.js"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "default": "./errors.js"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "default": "./events.js"
    },
    "./health": {
      "types": "./src/health/index.ts",
      "default": "./health.js"
    },
    "./http": {
      "types": "./src/http/index.ts",
      "default": "./http.js"
    },
    "./logger": {
      "types": "./src/logger/index.ts",
      "default": "./logger.js"
    },
    "./modules": {
      "types": "./src/modules/index.ts",
      "default": "./modules.js"
    },
    "./queue": {
      "types": "./src/queue/index.ts",
      "default": "./queue.js"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "default": "./storage.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test tools --ext .ts,.mjs",
    "format:check": "prettier . --check",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:exports": "npm run build && node tools/check-exports.mjs",
    "package:check": "npm run build && node tools/check-package.mjs",
    "package:check:installed": "npm run build && node tools/check-installed-package.mjs",
    "dependencies:check": "node tools/check-dependencies.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:exports && npm run package:check && npm run package:check:installed && npm run dependencies:check && npm run check:versions",
    "prepack": "npm run build",
    "version:show": "node tools/repository-release.mjs version:show",
    "version:bump": "node tools/repository-release.mjs version:bump",
    "check:versions": "node tools/repository-release.mjs check:versions",
    "github:now": "node tools/repository-release.mjs github:now"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "mariadb": "^3.5.3",
    "mysql2": "^3.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^7.0.2",
    "typescript-eslint-compiler": "npm:typescript@6.0.3"
  },
  "engines": {
    "node": ">=26.5.0",
    "npm": ">=12.0.1"
  }
}
